BAGU_AI_PROVIDER=openai-compatible

# Chat model, for example Volcengine Ark OpenAI-compatible endpoint.
BAGU_AI_CHAT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
BAGU_AI_CHAT_API_KEY=replace-with-your-chat-api-key
BAGU_AI_CHAT_MODEL=replace-with-your-chat-model

# Embedding model, for example DashScope OpenAI-compatible endpoint.
BAGU_AI_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAGU_AI_EMBEDDING_API_KEY=replace-with-your-embedding-api-key
BAGU_AI_EMBEDDING_MODEL=text-embedding-v4

